<?xml version="1.0" encoding="UTF-8" ?>
<flashtool-config version="2.0">
  <general>
    <chip-name>MT6580</chip-name>
    <storage-type>EMMC</storage-type>
    <download-agent>
      DA_SWSEC.bin
    </download-agent>
    <scatter>
      MT6580_Android_scatter.txt
    </scatter>
    <rom-list>
      <rom index="0" enable="true">
        preloader_mt8321_GO.bin
      </rom>
    </rom-list>
    <connection
      type="BromUSB"
      high-speed="false"
      without-battery="false" />
  </general>
  <commands>
    <efuse>
      <secure-ctrl
      	Enable_SW_JTAG_CON="true"
        Enable_SBC="true" />
   
      
      <sbc-pub-key>
        <pub-key-e>00010001</pub-key-e>
        <pub-key-n> 
        </pub-key-n>
      </sbc-pub-key>

      <secure-lock
        sec_attr_lock="true"
        sbc_pubk_hash_lock="true" />
      
      <read-back
        dir="."
        name="efuse_dump.txt"
        time-prefix="false" />
    </efuse>
  </commands>
</flashtool-config>
