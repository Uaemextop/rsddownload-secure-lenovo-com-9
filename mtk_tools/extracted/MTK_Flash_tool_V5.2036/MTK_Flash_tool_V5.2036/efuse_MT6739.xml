<?xml version="1.0" encoding="UTF-8" ?>
<flashtool-config version="2.0">
  <general>
    <chip-name>MT6739</chip-name>
    <storage-type>EMMC</storage-type>
    <download-agent>
      MTK_AllInOne_DA.bin
    </download-agent>
    <scatter>
      MT6739_Android_scatter.txt
    </scatter>
    <rom-list>
      <rom index="0" enable="true">
        preloader_mt8765_P.bin
      </rom>
    </rom-list>
    <connection
      type="BromUSB"
      high-speed="false"
  />
  </general>
  <commands>
    <efuse>
      <common-ctrl
        Disable_EMMC_boot="false"
        Disable_NAND_boot="false"
        Disable_NAND_boot_speedup="false"
        USB_download_type="0"/>
      <secure-ctrl
        Enable_ACC="false"
        Enable_ACK="false"
        Enable_SBC="true"
        Enable_SLA="false"
        Enable_DAA="false"
        Disable_JTAG="false"
        Enable_SW_JTAG_CON="false"/>
      
      <sbc-pub-key>
      	<key-type>pss</key-type>
        <pub-key-e>010001</pub-key-e>
        <pub-key-n>
          
        </pub-key-n>
      </sbc-pub-key>
      
      <common-lock
        com_ctrl_lock="false"
        usb_id_lock="false"/>
		
      <secure-lock
        sec_attr_lock="true"
        ackey_lock="false"
        sbc_pubk_hash_lock="true"/>
      <usb-id vid="0000" pid="0000"/>
	  <!--<ac-key>112233445566778899AABBCCDDEEFFFF</ac-key> -->  
         
      <c_ctrl_0
  	 	  c2k_sbc_en="false"
  	 	  md1_sbc_en="false" />
		  
      <read-back
        dir="."
        name="efuse_dump.txt"
        time-prefix="false"/>
    </efuse>
  </commands>
</flashtool-config>
