<?xml version="1.0" encoding="UTF-8" ?>
<flashtool-config version="2.0">
  <general>
    <chip-name>MT6785</chip-name>
    <storage-type>UFS</storage-type>
    <download-agent>
      MTK_AllInOne_DA_p11.bin
    </download-agent>
    <scatter>
      MT6785_Android_scatter.txt
    </scatter>
    <rom-list>
      <rom index="0" enable="true">
        preloader_p11.bin
      </rom>
    </rom-list>
    <connection
      type="BromUSB"
      high-speed="false"
      power="true"
      da_log_level="Info"
	  da_log_channel="UART" 
	/>
  </general>
  <commands>
    <efuse>
      <common-ctrl
		Disable_UFS_boot="false"          
        USB_download_type="0"
	    Disable_EMMC_boot="false"/>
        
      <secure-ctrl
	    Disable_DBGPORT_LOCK="false"
	    Enable_SW_JTAG_CON="false"
        Enable_ACC="false"
        Enable_ACK="false"
        Enable_SLA="false"
        Enable_DAA="true"
        Enable_SBC="true"
        Disable_JTAG="false" />
      <sbc-pub-key>
	    <key-type>pss</key-type>
        <pub-key-e>010001</pub-key-e>
        <pub-key-n>
                </pub-key-n>
      </sbc-pub-key> 
        
     <common-lock
        com_ctrl_lock="false"
        usb_id_lock="false" />
      <secure-lock
        sec_msc_lock="false"
        sec_attr_lock="false"
        ackey_lock="false"
        sbc_pubk_hash_lock="false"/>
        
      <usb-id vid="0000" pid="0000"/> 
	  
	  <sec_msc
        md1_sbc_en="false"
        c2k_sbc_en="false" />
	 	    
      <read-back
        dir="."
        name="efuse_dump.txt"
        time-prefix="false" />
    </efuse>
  </commands>
</flashtool-config>
