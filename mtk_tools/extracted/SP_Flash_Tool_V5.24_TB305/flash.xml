<?xml version="1.0" encoding="UTF-8" ?>
<flashtool-config version="2.0">
    <general>
        <chip-name>MT6768</chip-name>
        <storage-type>EMMC</storage-type>
        <download-agent>MTK_AllInOne_DA.bin</download-agent>
        <authentication>auth_sv5.auth</authentication>
        <certification></certification>
        <connection type="BromUSB" high-speed="true" power="AutoDetect" da_log_level="Info" da_log_channel="UART" timeout-count="3600000" com-port="" storage_life_cycle_check="true" />
        <checksum-level>none</checksum-level>
        <!--log_on: log switch, enable log if true, otherwise false;
			log_path: the directory in which the log files has been stored;
			clean_hours: the time setting to delete log files regularly, the unit is hours.-->
        <log-info log_on="true" log_path="C:\ProgramData\SP_FT_Logs" clean_hours="744" />
    </general>
    <commands>
        <firmware-upgrade>
            <scene>FIRMWARE_UPGRADE</scene>
            <readback>
                <physical-readback is-physical-readback="false" />
            </readback>
            <format validation="false" physical="false" erase-flag="NormalErase" auto-format="true" auto-format-flag="FormatAll" />
            <da-download-all />
            <write-memory>
                <write-memory-item input-mode="FromFile" program-mode="PageOnly" addr-mode="LogicalAddress" address="0x000000001f600000" input-length="0x00000000" part-id="0" is_by_sram="0"></write-memory-item>
            </write-memory>
        </firmware-upgrade>
    </commands>
</flashtool-config>
